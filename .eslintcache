"messages":"109","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\index.js",[],["110","111"],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\App.js",["112"],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\reportWebVitals.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\Home.js",["113"],"import React, {useEffect, useState} from \"react\";\r\nimport {useParams} from \"react-router-dom\";\r\nimport sanityClient from \"../client.js\";\r\nimport imageUrlBuilder from \"@sanity/image-url\";\r\nimport BlockContent from \"@sanity/block-content-to-react\";\r\nimport image from \"../images/Home Background.PNG\"\r\n\r\nconst builder = imageUrlBuilder(sanityClient);\r\n\r\nfunction urlFor(source) {\r\n    return builder.image(source);\r\n}\r\n\r\nexport default function Home() {\r\n    const [author, setAuthor] = useState(null);\r\n\r\n    useEffect(() => {\r\n        sanityClient.fetch(`*[_type == \"author\"] {\r\n            name,\r\n            bio,\r\n            \"authorImage\": image.asset->url\r\n        }`)\r\n        .then((data) => setAuthor(data[0]))\r\n        .catch(console.error);\r\n    }, []);\r\n\r\n    if (!author) {\r\n        return (\r\n            <main className=\"bg-blue-100 min-h-screen p-12\">\r\n                <div className=\"justify-center\">\r\n                    <h1 className=\"text-5xl text-center animate-pulse\">\r\n                        Loading...\r\n                    </h1>\r\n                </div>\r\n            </main>\r\n        )\r\n    }\r\n\r\n    return (\r\n        <main className=\"relative\">\r\n            <img src={image} alt=\"Star background\" className=\"absolute w-full\"/>\r\n            <div className=\"p-10 lg:pt-48 container mx-auto relative\">\r\n                <section className=\"bg-blue-800 rounded-lg shadow-2xl lg:flex p-20\">\r\n                    <div className=\"w-32 h-32 lg:w-64 lg:h-64 mr-8\">\r\n                        <img\r\n                            src={urlFor(author.authorImage).url()}\r\n                            className=\"bg-cover bg-center rounded\"\r\n                            alt={author.name}/>\r\n                    </div>\r\n                    <div className=\"text-lg flex flex-col justify-center\">\r\n                        <h1 className=\"cursive text-6xl text-blue-300 mb-4\">\r\n                            <span className=\"text-blue-100\">\r\n                                {author.name}\r\n                            </span>\r\n                        </h1>\r\n                        <div className=\"prose lg:prose-xl text-white\">\r\n                            <BlockContent\r\n                                blocks={author.bio}\r\n                                projectId=\"5zei2dq1\"\r\n                                dataset=\"production\"/>\r\n                        </div>\r\n                    </div>\r\n                </section>\r\n            </div>\r\n        </main>\r\n\r\n        /*\r\n        <main>\r\n            <img src={image} alt=\"Star Background\" className=\"absolute object-cover w-full h-full\" />\r\n            <section className=\"relative flex justify-center min-h-screen pt-12 lg:pt-64 px-8\">\r\n                <h1 className=\"text-6xl text-blue-100 font-bold cursive leading-none lg:leading-snug home-name\">\r\n                    Hi. I'm Min-Kyu.\r\n                </h1>\r\n            </section>\r\n        </main>\r\n        */\r\n    )\r\n}\r\n","D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\About.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\SinglePost.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\Project.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\Post.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\NavBar.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\client.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\Skill.js",[],"D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\Award.js",["114"],"import React, {useEffect, useState} from \"react\"\r\nimport sanityClient from \"../client.js\"\r\nimport BlockContent from \"@sanity/block-content-to-react\";\r\nimport Project from \"./Project.js\";\r\n\r\nconst months = [\r\n    \"January\",\r\n    \"Febuary\",\r\n    \"March\",\r\n    \"April\",\r\n    \"May\",\r\n    \"June\",\r\n    \"July\",\r\n    \"August\",\r\n    \"September\",\r\n    \"October\",\r\n    \"November\",\r\n    \"December\"\r\n]\r\n\r\nfunction sanityDateToString(sanityDate) {\r\n    if (sanityDate == null) {\r\n        return \"N/A\";\r\n    }\r\n    const dateVar = new Date(sanityDate);\r\n    return (months[dateVar.getMonth()] + \" \" + dateVar.getFullYear());\r\n}\r\n\r\nexport default function Award() {\r\n    const [awardData, setAwardData] = useState(null);\r\n\r\n    useEffect(() => {\r\n        sanityClient.fetch(`*[_type == \"award\"] | order(date desc){\r\n            name,\r\n            date,\r\n            organization,\r\n            description\r\n        }`)\r\n        .then((data) => setAwardData(data))\r\n        .catch(console.error);\r\n    }, []);\r\n\r\n    return (\r\n        <main className=\"bg-blue-100 min-h-screen p-12\">\r\n            <section className=\"container mx-auto\">\r\n                <h1 className=\"text-5xl flex justify-center cursive\">\r\n                    Awards\r\n                </h1>\r\n                <h2 className=\"text-lg text-gray-600 flex justify-center mb-12\">\r\n                    \r\n                </h2>\r\n                <section className=\"grid lg:grid-cols-2 gap-8\">\r\n                    {awardData && awardData.map((award, index) => (\r\n                        <article className=\"relative rounded-lg shadow-xl bg-white p-16\">\r\n                            <h3 className=\"text-gray-800 text-3xl font-bold mb-2 hover:text-blue-700\">\r\n                                {award.name}\r\n                            </h3>\r\n                            <div className=\"text-gray-500 text-s space-x-4\">\r\n                                <span>\r\n                                    <strong className=\"font-bold\">\r\n                                        Received on\r\n                                    </strong>:{\" \"}\r\n                                    {sanityDateToString(award.date)}\r\n                                </span>\r\n                                <span>\r\n                                    <strong className=\"font-bold\">\r\n                                        Organization\r\n                                    </strong>:{\" \"}\r\n                                    {award.organization}\r\n                                </span>\r\n                                <div className=\"my-6 text-lg text-gray-700 leading-relaxed\">\r\n                                    <BlockContent\r\n                                            blocks={award.description}\r\n                                            projectId=\"5zei2dq1\"\r\n                                            dataset=\"production\"/>\r\n                                </div>\r\n                            </div>\r\n                        </article>\r\n                    ))}\r\n                </section>\r\n            </section>\r\n        </main>\r\n    );\r\n}\r\n","D:\\mookwooj\\Documents\\Personal\\Personal Proper\\Projects\\Programming\\JavaScript\\portfoliowebsite\\src\\components\\Experience.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\index.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\App.js",["115"],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\reportWebVitals.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\Home.js",["116"],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\About.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\SinglePost.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\Post.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\Project.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\NavBar.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\Award.js",["117"],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\Experience.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\components\\Skill.js",[],"D:\\mookwooj\\Documents\\Personal\\GitHub\\leeminkyu16.github.io\\src\\client.js",[],{"ruleId":"118","replacedBy":"119"},{"ruleId":"120","replacedBy":"121"},{"ruleId":"122","severity":1,"message":"123","line":1,"column":31,"nodeType":"124","messageId":"125","endLine":1,"endColumn":37},{"ruleId":"122","severity":1,"message":"126","line":2,"column":9,"nodeType":"124","messageId":"125","endLine":2,"endColumn":18},{"ruleId":"122","severity":1,"message":"127","line":4,"column":8,"nodeType":"124","messageId":"125","endLine":4,"endC